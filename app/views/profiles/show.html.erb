<% content_for :title, t("settings.title") %>
<% content_for :breadcrumb_standalone, t("settings.title") %>

<div class="space-y-6 mt-12">
  <!-- Section 1: Profile -->
  <div class="bg-bg-surface border border-border rounded-lg p-5 space-y-4">
    <h3 class="text-xs font-medium text-content-muted uppercase tracking-wider font-display"><%= t("settings.profile.section_title") %></h3>

    <%= form_with(model: @user, url: settings_path, method: :patch, class: "space-y-4") do |form| %>
      <!-- Avatar -->
      <div>
        <label class="block text-xs font-medium text-content-secondary mb-2"><%= t("settings.profile.avatar") %></label>
        <div class="flex items-center gap-4">
          <% if @user.has_avatar? %>
            <%= image_tag @user.avatar_source, class: "w-14 h-14 object-cover rounded-full" %>
          <% else %>
            <div class="w-14 h-14 rounded-full bg-bg-elevated flex items-center justify-center">
              <svg class="w-7 h-7 text-content-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
          <% end %>
          <div class="flex-1">
            <%= form.file_field :avatar, accept: "image/jpeg,image/jpg,image/png,image/webp", class: "block w-full text-xs text-content-secondary file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-bg-elevated file:text-content-secondary hover:file:bg-bg-hover file:cursor-pointer file:transition-colors" %>
            <p class="text-xs text-content-muted mt-1"><%= t("settings.profile.avatar_hint") %></p>
          </div>
        </div>
        <% if @user.avatar.attached? || @user.avatar_url.present? %>
          <div class="mt-3">
            <label class="flex items-center text-xs text-content-secondary cursor-pointer">
              <%= form.check_box :remove_avatar, class: "mr-2 rounded border-border bg-bg-elevated text-accent focus:ring-accent focus:ring-offset-bg-surface" %>
              <%= t("settings.profile.remove_avatar") %>
            </label>
          </div>
        <% end %>
        <% if @user.errors[:avatar].any? %>
          <div class="mt-2">
            <% @user.errors[:avatar].each do |error| %>
              <p class="text-status-error text-xs"><%= t("settings.profile.avatar") %> <%= error %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Email -->
      <div class="pt-4 border-t border-border">
        <label class="block text-xs font-medium text-content-secondary mb-1.5"><%= t("settings.profile.email") %></label>
        <%= form.email_field :email_address, placeholder: "your@email.com", class: "block w-full bg-bg-elevated border-0 rounded-md px-3 py-2 text-sm text-content placeholder:text-content-muted focus:ring-1 focus:ring-accent focus:outline-none" %>
        <% if @user.errors[:email_address].any? %>
          <div class="mt-1">
            <% @user.errors[:email_address].each do |error| %>
              <p class="text-status-error text-xs"><%= t("settings.profile.email") %> <%= error %></p>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="pt-2">
        <%= form.submit t("settings.profile.save_profile"), class: "cursor-pointer px-4 py-2 bg-accent text-content hover:bg-accent-hover text-xs font-semibold rounded-md transition-colors duration-200" %>
      </div>
    <% end %>
  </div>

  <div class="bg-bg-surface border border-border rounded-lg p-5 space-y-4">
    <h3 class="text-xs font-medium text-content-muted uppercase tracking-wider font-display"><%= t("common.language") %></h3>
    <%= form_with url: locale_path, method: :patch do %>
      <%= select_tag :locale,
          options_for_select([[t("common.chinese"), "zh-CN"], [t("common.english"), "en"]], I18n.locale.to_s),
          onchange: "this.form.submit()",
          class: "block w-full bg-bg-elevated border-0 rounded-md px-3 py-2 text-sm text-content focus:ring-1 focus:ring-accent focus:outline-none" %>
    <% end %>
  </div>

  <!-- Section 2: OpenClaw Integration -->
  <div class="bg-bg-surface border border-border rounded-lg p-5 space-y-4">
    <div class="flex items-center gap-2">
      <span class="text-lg">🦞</span>
      <h3 class="text-sm font-semibold text-content font-display"><%= t("settings.agent.title") %></h3>
    </div>

    <p class="text-xs text-content-secondary">
      <%= t("settings.agent.description") %>
    </p>

    <% api_url = "#{request.base_url}/api/v1" %>
    <% api_token = @api_token.token %>

    <!-- Comprehensive agent prompt -->
    <div
      data-controller="clipboard"
      data-clipboard-copied-value="<%= t("common.copied") %>"
      data-clipboard-failed-value="<%= t("common.failed") %>"
      data-clipboard-copy-value="<%= t("common.copy") %>"
    >
      <div class="bg-bg-elevated rounded-md max-h-96 overflow-y-auto">
        <pre
          data-clipboard-target="source"
          class="px-3 py-3 text-xs font-mono text-content-secondary whitespace-pre-wrap break-words leading-relaxed"
># ClawDeck — Your Task Dashboard

ClawDeck 是你的“任务控制台”，人类在这里管理你的工作队列。你可以把它理解成你们共享的看板。

## 工作方式

1. 人类创建任务并在看板上整理
2. 人类在合适的时候显式将任务分配给你
3. 你轮询获取已分配任务并开始执行
4. 你更新进度并标记完成
5. 人类可以实时看到你的状态与更新

## 连接信息

- **API URL:** <%= api_url %>
- **Token:** <%= api_token %>
- **Auth Header:** `Authorization: Bearer <%= api_token %>`

## 标识你的身份

每次请求都必须携带以下 header，便于人类知道是哪一个 Agent 连接上来了：
- `X-Agent-Name`: Your name (e.g., "<%= @user.agent_name.presence || "OpenClaw" %>")
- `X-Agent-Emoji`: Your emoji (e.g., "<%= @user.agent_emoji.presence || "🦞" %>")

## 你的工作流

### 轮询已分配任务（每 30 秒或心跳触发）：
1. 调用 `GET /tasks?assigned=true` 获取分配给你的任务
2. 选择第一个任务（最早分配的）
3. 将其状态改为 `in_progress` 并开始执行

### 执行任务时：
- **需要协助**：将 `blocked: true`，并在 activity_note 中说明原因，人类会帮你解除阻塞
- **完成**：将状态改为 `in_review`（需要人类审核）或 `done`（完全完成）

### 你也可以：
- 创建新任务（灵感、后续事项、你发现的问题）
- 查看任务详情与历史记录

## API 参考

**获取已分配任务（你的工作队列）：**
`GET /tasks?assigned=true`
返回分配给你的任务，按分配时间排序（最早优先）。

**列出所有任务：**
`GET /tasks` or `GET /tasks?status=in_progress`

**获取单个任务：**
`GET /tasks/:id`

**更新任务：**
`PATCH /tasks/:id`
Body: `{ "status": "in_progress" }` or `{ "blocked": true }`

**切换完成状态：**
`PATCH /tasks/:id/complete`

**创建任务：**
`POST /tasks`
Body: `{ "name": "Task title", "status": "inbox" }`

## 状态（Statuses）
- `inbox` — 新任务/想法，未优先排序
- `up_next` — 已排优先级，等待分配
- `in_progress` — 你正在执行
- `in_review` — 你已完成，等待人类审核
- `done` — 完成

## 优先级（Priorities）
`none`, `low`, `medium`, `high`

## 输出语言要求（重要）
- 除非用户明确要求英文，否则你的回复与 activity_note 都使用中文
- 任务描述/总结尽量简洁清晰，方便人类快速审核

## 小提示
- 频繁轮询已分配任务：人类会显式把任务分配给你
- 卡住时立刻标记 blocked 并说明需要什么信息
- 你发现但暂时做不了的事，先创建成任务，避免遗忘</pre>
      </div>
      <div class="flex items-center gap-3 mt-2">
        <button
          type="button"
          data-action="click->clipboard#copy"
          class="cursor-pointer px-3 py-1.5 bg-bg-elevated hover:bg-bg-hover text-content-secondary text-xs font-medium rounded-md transition-colors"
        >
          <span data-clipboard-target="label"><%= t("common.copy") %></span>
        </button>
        <%= button_to t("settings.agent.regenerate_token"), regenerate_api_token_settings_path,
            method: :post,
            data: { turbo_confirm: t("settings.agent.regenerate_confirm") },
            class: "cursor-pointer text-xs text-content-muted hover:text-content-secondary transition-colors" %>
      </div>
    </div>

    <!-- Connected Agent (within same box) -->
    <div class="pt-4 border-t border-border">
      <p class="text-xs font-medium text-content-secondary mb-3"><%= t("settings.agent.connected_agent") %></p>

      <% if @user.agent_last_active_at.present? %>
        <div class="flex items-center gap-3">
          <span class="text-xl"><%= @user.agent_emoji || "🦞" %></span>
          <span class="text-sm text-content"><%= @user.agent_name || "Agent" %></span>
          <span class="text-xs text-content-muted">•</span>
          <span class="text-xs text-content-muted"><%= t("settings.agent.last_active", time: time_ago_in_words(@user.agent_last_active_at)) %></span>
        </div>
      <% else %>
        <p class="text-xs text-content-muted"><%= t("settings.agent.no_agent") %></p>
      <% end %>
    </div>
  </div>
</div>
